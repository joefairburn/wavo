{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "es2018",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "lib": ["es2018", "dom", "dom.iterable"],
    "strict": true,
    "strictNullChecks": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
