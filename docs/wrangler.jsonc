{
  "name": "wavo-docs",
  "main": "./src/waku.server",
  "compatibility_flags": ["nodejs_compat"],
  "compatibility_date": "2026-01-25",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist/public",
    "html_handling": "drop-trailing-slash"
  },
  "rules": [{ "type": "ESModule", "globs": ["**/*.js", "**/*.mjs"] }],
  "no_bundle": true
}
