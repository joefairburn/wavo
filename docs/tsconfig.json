{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@docs/*": ["./src/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", ".source"]
}
